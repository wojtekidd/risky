{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "ckm-playbook-template-v1",
  "title": "CKM Playbook Template",
  "description": "Schema for validating ClaudeKit Marketing playbook templates",
  "type": "object",
  "required": ["id", "name", "version", "stages"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Unique template identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable template name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (major.minor.patch)"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "estimatedDuration": {
      "type": "string",
      "description": "Human-readable duration estimate"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "ai_models_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputs": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "type", "prompt"],
            "properties": {
              "key": { "type": "string" },
              "type": { "type": "string", "enum": ["string", "number", "boolean", "url", "date", "array"] },
              "prompt": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "type", "prompt"],
            "properties": {
              "key": { "type": "string" },
              "type": { "type": "string", "enum": ["string", "number", "boolean", "url", "date", "array"] },
              "default": {},
              "prompt": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "goal_targets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["default", "metric"],
        "properties": {
          "default": { "type": "number" },
          "metric": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "steps"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/step" }
          }
        },
        "additionalProperties": false
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["auto", "manual"] },
          "checker": { "type": "string" },
          "criteria": { "type": "array", "items": { "type": "string" } },
          "pass_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
          "prompt": { "type": "string" },
          "blocksAll": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "name", "strategy", "ai_execution", "human_decision"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "strategy": { "type": "string", "minLength": 20, "description": "Expert reasoning — substantive advice" },
        "ai_execution": { "type": "string", "minLength": 20, "description": "How AI accelerates this step" },
        "human_decision": { "type": "string", "minLength": 20, "description": "What requires human judgment" },
        "command": { "type": "string" },
        "agent": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "parallel": { "type": "boolean", "default": false },
        "gate": { "type": ["string", "null"], "default": null }
      },
      "additionalProperties": false
    }
  }
}
